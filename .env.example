# ============================================================
# Variables d'environnement — Projet Entan
# À renseigner dans .env.local (dev) ET dans Vercel → Settings →
# Environment Variables (production). Ne jamais committer .env.local.
# ============================================================

# --- Supabase (Dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Clé "service_role" — SECRET, serveur uniquement (webhook Stripe). Ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Emails transactionnels (Resend + Send Email Hook Supabase) ---
RESEND_API_KEY=re_xxx
# Adresse d'expéditeur : DOIT être sur un domaine VÉRIFIÉ dans Resend,
# sinon les emails partent en spam ou ne sont envoyés qu'à votre propre adresse.
RESEND_FROM=Projet Entan <no-reply@votre-domaine.fr>
# Secret du Send Email Hook (Supabase → Auth → Hooks), format "v1,whsec_...".
SEND_EMAIL_HOOK_SECRET=v1,whsec_xxx

# --- Stripe (facturation par siège) ---
STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SEAT=price_xxx

# --- Divers ---
# URL publique de production (retours Stripe, liens & images des emails). Ex : https://votre-domaine.fr
NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr
# Secret du cron de rappels (Vercel Cron l'envoie en « Authorization: Bearer … »).
CRON_SECRET=chaine-aleatoire-longue
